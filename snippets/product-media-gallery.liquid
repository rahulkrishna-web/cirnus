{% comment %}
  Renders a product media gallery

  Accepts:
  - product: {Object} Product Liquid object

  Usage:
  {% render 'product-media-gallery' %}
{% endcomment %}

{%- liquid
  if section.settings.hide_variants_if_single and product.has_only_default_variant
    assign hide_mobile_slider = true
  endif
-%}

<media-gallery id="MediaGallery-{{ section.id }}" role="region" aria-label="Gallery viewer" data-desktop-layout="{{ section.settings.gallery_layout }}">
  <div id="GalleryStatus-{{ section.id }}" class="visually-hidden" role="status"></div>
  
  <div class="product__media-list-wrapper">
    <ul id="Slider-Gallery-{{ section.id }}" class="product__media-list grid grid--1-col slider slider--mobile {% if hide_mobile_slider %} slider--desktop-only{% endif %}" role="list">
      {%- if product.selected_or_first_available_variant.featured_media != null -%}
        {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
        <li id="Slide-{{ section.id }}-{{ featured_media.id }}" class="product__media-item grid__item slider__slide is-active" data-media-id="{{ section.id }}-{{ featured_media.id }}">
          <div class="product__media media media--transparent" style="padding-top: {{ 1 | divided_by: featured_media.aspect_ratio | times: 100 }}%;">
            <img
              srcset="{% if featured_media.preview_image.width >= 288 %}{{ featured_media.preview_image | image_url: width: 288 }} 288w,{% endif %}
                      {% if featured_media.preview_image.width >= 576 %}{{ featured_media.preview_image | image_url: width: 576 }} 576w,{% endif %}
                      {% if featured_media.preview_image.width >= 750 %}{{ featured_media.preview_image | image_url: width: 750 }} 750w,{% endif %}
                      {% if featured_media.preview_image.width >= 1100 %}{{ featured_media.preview_image | image_url: width: 1100 }} 1100w,{% endif %}"
              src="{{ featured_media | image_url: width: 750 }}"
              sizes="(min-width: 1200px) calc((1200px - 10rem) / 2), (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)"
              loading="eager"
              fetchpriority="high"
              width="750"
              height="{{ 750 | divided_by: featured_media.preview_image.aspect_ratio | ceil }}"
              alt="{{ featured_media.preview_image.alt | escape }}"
            >
          </div>
        </li>
      {%- endif -%}

      {%- for media in product.media -%}
        {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
          <li id="Slide-{{ section.id }}-{{ media.id }}" class="product__media-item grid__item slider__slide" data-media-id="{{ section.id }}-{{ media.id }}">
            <div class="product__media media media--transparent" style="padding-top: {{ 1 | divided_by: media.aspect_ratio | times: 100 }}%;">
              <img
                srcset="{% if media.preview_image.width >= 288 %}{{ media.preview_image | image_url: width: 288 }} 288w,{% endif %}
                        {% if media.preview_image.width >= 576 %}{{ media.preview_image | image_url: width: 576 }} 576w,{% endif %}
                        {% if media.preview_image.width >= 750 %}{{ media.preview_image | image_url: width: 750 }} 750w,{% endif %}
                        {% if media.preview_image.width >= 1100 %}{{ media.preview_image | image_url: width: 1100 }} 1100w,{% endif %}"
                src="{{ media | image_url: width: 750 }}"
                sizes="(min-width: 1200px) calc((1200px - 10rem) / 2), (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)"
                loading="lazy"
                width="750"
                height="{{ 750 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                alt="{{ media.preview_image.alt | escape }}"
              >
            </div>
          </li>
        {%- endunless -%}
      {%- endfor -%}
    </ul>
  </div>

  {%- if product.media.size > 1 and section.settings.gallery_layout contains 'thumbnails' -%}
    <div class="slider-buttons no-js-hidden" data-media-count="{{ product.media.size }}">
       <!-- Simplified pager for minimal DOM -->
      <slider-component class="thumbnail-slider slider-mobile-gutter">
        <ul class="thumbnail-list list-unstyled slider slider--mobile" id="GalleryThumbnails-{{ section.id }}">
          {%- capture sizes -%}
            (min-width: 1200px) calc((1200px - 10rem) / 4), (min-width: 750px) calc((100vw - 11.5rem) / 4), calc(100vw - 4rem)
          {%- endcapture -%}
          {%- for media in product.media -%}
            <li id="Slide-Thumbnails-{{ section.id }}-{{ forloop.index }}" class="thumbnail-list__item slider__slide{% if media.id == featured_media.id %} is-active{% endif %}" data-target="{{ section.id }}-{{ media.id }}" data-media-position="{{ forloop.index }}">
              <button class="thumbnail global-media-settings shadow-sm color-background-1" aria-current="{% if media.id == featured_media.id %}true{% else %}false{% endif %}">
                <img
                  srcset="{{ media.preview_image | image_url: width: 416 }} 416w"
                  src="{{ media | image_url: width: 416 }}"
                  sizes="{{ sizes }}"
                  alt="{{ media.preview_image.alt | escape }}"
                  height="208"
                  width="208"
                  loading="lazy"
                  class="thumbnail__image"
                >
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </slider-component>
    </div>
  {%- endif -%}
</media-gallery>

{% stylesheet %}
  .product__media-list-wrapper {
    position: relative;
    overflow: hidden;
  }
  
  .product__media-list {
    display: flex;
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
  
  .product__media-item {
    width: 100%;
    flex-shrink: 0;
    scroll-snap-align: start;
    position: relative;
  }

  .product__media {
    position: relative;
    display: block;
    width: 100%;
  }

  .product__media img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Desktop Stacked */
  @media screen and (min-width: 990px) {
    media-gallery[data-desktop-layout="stacked"] .product__media-list {
      flex-direction: column;
      overflow-x: visible;
    }
    media-gallery[data-desktop-layout="stacked"] .product__media-item {
      margin-bottom: 2rem;
    }
  }

  /* Thumbnails */
  .thumbnail-list {
    display: flex;
    overflow-x: auto;
    padding: 1rem 0;
    gap: 1rem;
    margin: 0;
    list-style: none;
  }

  .thumbnail-list__item {
    flex-shrink: 0;
    width: 80px;
  }

  .thumbnail {
    display: block;
    width: 100%;
    padding: 0;
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .thumbnail[aria-current="true"] {
    border-color: rgba(var(--color-foreground), 1);
  }

  .thumbnail__image {
    width: 100%;
    height: auto;
    display: block;
  }
{% endstylesheet %}
