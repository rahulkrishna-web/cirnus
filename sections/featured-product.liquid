<div class="featured-product section-{{ section.id }}-padding" style="--media-size: {{ section.settings.media_size }};">
  <div class="page-width">
    {%- assign product = section.settings.product -%}

    <div class="product product--featured grid grid--1-col grid--2-col-desktop">
      
      <div class="grid__item product__media-wrapper">
        {%- if product != blank -%}
          {%- if product.media.size > 0 -%}
             {% render 'product-media-gallery', product: product %}
          {%- else -%}
            <div class="product__media-placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg placeholder-svg--product' }}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="product__media-placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg placeholder-svg--product' }}
          </div>
        {%- endif -%}
      </div>

      <div class="grid__item product__info-wrapper">
        <div class="product__info-container" id="ProductInfo-{{ section.id }}">
          
          {%- if product != blank -%}
            <h2 class="product__title h2">
              <a href="{{ product.url }}">{{ product.title | escape }}</a>
            </h2>

            <div class="price price--large" id="price-{{ section.id }}">
              {%- if product.compare_at_price > product.price -%}
                <s class="price__regular">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
              <span class="price__sale">{{ product.price | money }}</span>
            </div>

            {%- if section.settings.show_description and product.description != blank -%}
              <div class="product__description rte">
                {{ product.description | strip_html | truncatewords: 30 }}
                <a href="{{ product.url }}" class="link">{{ 'products.product.view_full_details' | t: default: 'View full details' }}</a>
              </div>
            {%- endif -%}

            {%- unless product.has_only_default_variant -%}
              <variant-radios class="no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}">
                {%- for option in product.options_with_values -%}
                  <fieldset class="js product-form__input">
                    <legend class="form__label">{{ option.name }}</legend>
                    {%- for value in option.values -%}
                      <input 
                        type="radio" 
                        id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                        name="{{ option.name }}"
                        value="{{ value | escape }}"
                        form="ProductForm-{{ section.id }}"
                        {% if option.selected_value == value %}checked{% endif %}
                      >
                      <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                        {{ value }}
                      </label>
                    {%- endfor -%}
                  </fieldset>
                {%- endfor -%}
                <script type="application/json">
                  {{ product.variants | json }}
                </script>
              </variant-radios>
            {%- endunless -%}

            <div class="product-form__error-message-wrapper" role="alert" hidden>
              <span class="product-form__error-message"></span>
            </div>

            <form method="post" action="/cart/add" id="ProductForm-{{ section.id }}" class="product-form">
               <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
               <div class="product-form__buttons">
                 <button
                   type="submit"
                   name="add"
                   class="product-form__submit button button--full-width button--primary"
                   {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                 >
                   <span>
                     {%- if product.selected_or_first_available_variant.available -%}
                       {{ 'products.product.add_to_cart' | t }}
                     {%- else -%}
                       {{ 'products.product.sold_out' | t }}
                     {%- endif -%}
                   </span>
                   <div class="loading-overlay__spinner hidden">
                      <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                        <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                      </svg>
                   </div>
                 </button>
               </div>
            </form>

          {%- else -%}
             <h2 class="product__title h2">{{ 'onboarding.product_title' | t: default: 'Example Product Title' }}</h2>
             <div class="price price--large">
               <span class="price__sale">$19.99</span>
             </div>
             <div class="product__description rte">
               <p>{{ 'onboarding.product_description' | t: default: 'This area is used to describe your product’s details, parts, sizing, and material.' }}</p>
             </div>
             <button type="button" class="product-form__submit button button--full-width button--primary" disabled>
               {{ 'products.product.add_to_cart' | t }}
             </button>
          {%- endif -%}

        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .featured-product {
    --media-size: 50%; /* Overridden via inline style setting */
    display: block;
  }

  /* Grid Layout reusing main-product struct */
  .product--featured {
    gap: 4rem;
  }

  @media screen and (min-width: 750px) {
    .product--featured {
      align-items: center; /* Center product info vertically with media */
    }
    .product--featured .product__media-wrapper {
      width: var(--media-size);
    }
    .product--featured .product__info-wrapper {
      width: calc(100% - var(--media-size) - 4rem);
    }
  }

  .product__title a {
    color: inherit;
    text-decoration: none;
  }
  
  .product__title a:hover {
    text-decoration: underline;
  }

  .product__media-placeholder svg {
    width: 100%;
    height: auto;
    background: #f4f4f4;
    aspect-ratio: 1 / 1;
    border-radius: var(--media-radius, 8px);
  }
  
  /* Fallback structural styling mirroring main-product if styles bundle is delayed */
  .product__info-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
{% endstylesheet %}

<script>
  // Lazy-load the product-info.js (VariantRadios) if not already loaded by main PDP
  if (!customElements.get('variant-radios')) {
     const script = document.createElement('script');
     script.src = "{{ 'product-info.js' | asset_url }}";
     script.defer = true;
     document.head.appendChild(script);
  }
</script>

{% schema %}
{
  "name": "Featured Product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show short description",
      "default": true
    },
    {
      "type": "select",
      "id": "media_size",
      "label": "Desktop Media Width",
      "options": [
        { "value": "40%", "label": "Small" },
        { "value": "50%", "label": "Medium" },
        { "value": "60%", "label": "Large" }
      ],
      "default": "50%"
    }
  ],
  "presets": [
    {
      "name": "Featured Product"
    }
  ]
}
{% endschema %}
