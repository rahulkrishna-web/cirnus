{%- if section.settings.sticky_header -%}
  <script src="{{ 'sticky-header.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% stylesheet %}
  .site-header {
    --header-menu-alignment: var(--header-alignment, flex-start);
  }
  
  /* Sticky CSS baseline */
  sticky-header {
    display: block;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  sticky-header[data-sticky-type="always"] {
    transition: transform 0.2s ease-in-out;
  }
  sticky-header[data-sticky-type="on-scroll-up"] {
    transition: transform 0.2s ease-in-out;
  }
  sticky-header.header-hidden {
    transform: translateY(-100%);
  }
{% endstylesheet %}

{%- if section.settings.sticky_header -%}
  <sticky-header data-sticky-type="on-scroll-up" class="header-wrapper">
{%- else -%}
  <div class="header-wrapper">
{%- endif -%}
  <header
    class="site-header header--{{ section.settings.logo_position }} page-width"
    data-header-section
  >
    <style>
      #shopify-section-{{ section.id }} .site-header {
        --header-alignment: {{ section.settings.menu_alignment }};
      }
    </style>
    <div class="header__content">
    {%- comment -%} Hamburger — mobile only, CSS hides on desktop {%- endcomment -%}
    <div class="header__hamburger-wrap">
      <button
        type="button"
        class="header__hamburger"
        data-hamburger
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="HeaderNav-{{ section.id }}"
      >
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
      </button>
    </div>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="header__logo-wrapper">
      <a href="{{ routes.root_url }}" class="header__heading-link logo-wrapper">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 600
            | image_tag: loading: 'eager', width: section.settings.logo_width, height: 'auto'
          }}
        {%- else -%}
          <div class="logo-container">
            {% render 'icon-logo-shapes' %}
            <span class="h2 logo-text">{{ shop.name }}</span>
          </div>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%}
      Single-source nav — rendered ONCE.
      Desktop: horizontal flex row.
      Mobile: slide-down drawer (CSS-driven, JS enhances).
    {%- endcomment -%}
    <nav class="header__nav" id="HeaderNav-{{ section.id }}" data-nav aria-label="Main navigation">
      <ul class="header__nav-list" role="list">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="header__nav-link"
              {%- if link.active %}
                aria-current="page"
              {% endif %}
            >
              <span
                {%- if link.active %}
                  class="header__active-menu-item"
                {% endif %}
              >
                {{- link.title | escape -}}
              </span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Icons (Right) {%- endcomment -%}
    <div class="header__icons">
      <a href="{{ routes.search_url }}" class="header__icon header__icon--search-desktop link focus-inset">
        {% render 'icon-search' %}
        <span class="visually-hidden">Search</span>
      </a>
      <a href="{{ routes.account_url }}" class="header__icon link focus-inset">
        {% render 'icon-account' %}
        <span class="visually-hidden">Account</span>
      </a>
      <a href="{{ routes.cart_url }}" class="header__icon link focus-inset" id="cart-icon-bubble">
        {% render 'icon-cart' %}
        <span class="visually-hidden">Cart</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ cart.item_count }} items</span>
          </div>
        {%- endif -%}
      </a>
    </div>
  </div>

  {%- comment -%} Overlay — click to close on mobile {%- endcomment -%}
  <div class="header__overlay" data-overlay></div>
</header>
{%- if section.settings.sticky_header -%}
  </sticky-header>
{%- else -%}
  </div>
{%- endif -%}

{%- comment -%}
  Lazy-load drawer JS on first hamburger interaction.
  No JS runs on page load — rule 3.1.
{%- endcomment -%}
<script>
  (function() {
    var btn = document.querySelector('[data-header-section] [data-hamburger]');
    if (!btn) return;
    var loaded = false;
    btn.addEventListener('pointerdown', function() {
      if (loaded) return;
      loaded = true;
      btn.setAttribute('data-pending-open', '');
      var s = document.createElement('script');
      s.src = {{ 'header-drawer.js' | asset_url | json }};
      document.head.appendChild(s);
    }, { once: false });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Custom logo width"
    },
    {
      "type": "select",
      "id": "menu_alignment",
      "label": "Menu Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
