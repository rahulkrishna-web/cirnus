<div class="collection-list-section section-{{ section.id }}-padding" style="--columns-desktop: {{ section.settings.columns_desktop }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="collection-list__header">
        <h2 class="collection-list__heading h2">{{ section.settings.title | escape }}</h2>
        {%- if section.settings.show_view_all -%}
           <a href="{{ routes.collections_url }}" class="link collection-list__view-all" aria-label="View all categories">{{ 'sections.collection_list.view_all' | t: default: 'View All' }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collection-list__wrapper {% if section.settings.swipe_on_mobile %}collection-list__wrapper--swipeable{% endif %}">
      <ul class="collection-list__grid list-unstyled" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection' -%}
            {%- assign featured_collection = block.settings.collection -%}
            <li class="collection-list__item" {{ block.shopify_attributes }}>
              <a 
                {% if featured_collection != blank and featured_collection.all_products_count > 0 %} href="{{ featured_collection.url }}"{% else %} role="link" aria-disabled="true"{% endif %} 
                class="collection-list__card collection-list__card--{{ section.settings.image_ratio }}"
              >
                <div class="collection-list__media">
                   {%- if featured_collection != blank and featured_collection.featured_image != blank -%}
                     <img
                       src="{{ featured_collection.featured_image | image_url: width: 600 }}"
                       alt="{{ featured_collection.title | escape }}"
                       loading="lazy"
                       height="{{ featured_collection.featured_image.height }}"
                       width="{{ featured_collection.featured_image.width }}"
                     >
                   {%- else -%}
                     {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg placeholder-svg--collection' }}
                   {%- endif -%}
                </div>
                
                <div class="collection-list__content">
                  <h3 class="collection-list__title h4">
                    {%- if featured_collection != blank -%}
                      {{ featured_collection.title | escape }}
                    {%- else -%}
                      {{ 'onboarding.collection_title' | t: default: 'Category title' }}
                    {%- endif -%}
                  </h3>
                  {%- if section.settings.show_count and featured_collection != blank -%}
                     <span class="collection-list__count">{{ featured_collection.all_products_count }} {{ 'sections.collection_list.items' | t: default: 'items' }}</span>
                  {%- endif -%}
                </div>
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

{% stylesheet %}
  .collection-list-section {
    --gap-desktop: 2rem;
    --gap-mobile: 1.5rem;
  }

  .collection-list__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .collection-list__heading {
    margin: 0;
  }

  .collection-list__view-all {
    font-weight: 500;
  }

  .collection-list__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-desktop, 4), 1fr);
    gap: var(--gap-desktop);
    margin: 0;
    padding: 0;
  }

  .collection-list__card {
    display: block;
    position: relative;
    text-decoration: none;
    border-radius: var(--media-radius, 8px);
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.03);
    height: 100%;
    transform: translateZ(0); /* Hardware accel for hover scale */
  }

  /* Image Ratios */
  .collection-list__card--square .collection-list__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  .collection-list__card--portrait .collection-list__media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
  }
  
  .collection-list__card--round {
    border-radius: 50%;
  }
  
  .collection-list__card--round .collection-list__media {
    aspect-ratio: 1 / 1;
  }

  /* Content Overlay vs Below Image */
  .collection-list__card--square .collection-list__content,
  .collection-list__card--portrait .collection-list__content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    z-index: 2;
  }
  
  .collection-list__card--round .collection-list__content {
    text-align: center;
    padding-top: 1.5rem;
    color: rgb(var(--color-foreground));
  }

  .collection-list__media img,
  .collection-list__media svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .collection-list__card:hover .collection-list__media img {
    transform: scale(1.05);
  }

  .collection-list__title {
    margin: 0;
    color: inherit;
    font-size: 1.6rem;
  }
  
  .collection-list__card--round .collection-list__title {
    font-size: 1.4rem;
  }

  .collection-list__count {
    font-size: 1.2rem;
    opacity: 0.8;
    margin-top: 0.5rem;
    display: block;
  }

  /* Mobile Swipe Logic (No JS) */
  @media screen and (max-width: 749px) {
    .collection-list__wrapper--swipeable {
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    
    .collection-list__wrapper--swipeable::-webkit-scrollbar {
      display: none;
    }

    .collection-list__wrapper--swipeable .collection-list__grid {
      display: flex;
      flex-wrap: nowrap;
      gap: var(--gap-mobile);
      /* Extra padding to allow scrolling past the last item */
      padding-right: 3rem; 
    }

    .collection-list__wrapper--swipeable .collection-list__item {
      flex: 0 0 calc(75vw - 1.5rem); /* Allows peeking of the next card */
      scroll-snap-align: start;
    }
    
    /* If swipe is disabled, just stack or use smaller grid */
    .collection-list__wrapper:not(.collection-list__wrapper--swipeable) .collection-list__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--gap-mobile);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' link",
      "default": false
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Desktop columns",
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Card shape",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "round", "label": "Round" }
      ],
      "default": "square"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "label": "Enable swipe on mobile",
      "info": "Creates a horizontal scrolling experience.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 12,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
