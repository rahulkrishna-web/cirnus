<div class="product-bundle section-{{ section.id }}-padding" style="--bundle-layout: {{ section.settings.layout_mobile }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="product-bundle__heading h2">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <product-bundle class="product-bundle__wrapper block">
      <div class="product-bundle__items" id="BundleItems-{{ section.id }}">
        
        {%- comment -%} Main Product Display (Anchor) {%- endcomment -%}
        {%- if product != blank -%}
          <div class="bundle-item bundle-item--main">
             <div class="bundle-item__media">
               <img src="{{ product.featured_media | image_url: width: 300 }}" alt="{{ product.title | escape }}" width="150" height="150" loading="lazy">
             </div>
             <div class="bundle-item__info">
               <label class="bundle-item__checkbox-wrapper">
                 <input type="checkbox" class="bundle-item__checkbox" checked disabled data-price="{{ product.price }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                 <span class="bundle-item__title">{{ 'products.product.this_item' | t }}: {{ product.title }}</span>
               </label>
               <span class="bundle-item__price price">{{ product.price | money }}</span>
             </div>
          </div>
          <div class="bundle-item__connector"><svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></div>
        {%- endif -%}

        {%- comment -%} Suggested Products (Metafields or Blocks) {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- assign bundle_product = block.settings.product -%}
          {%- if bundle_product != blank -%}
            <div class="bundle-item">
               <div class="bundle-item__media">
                 <a href="{{ bundle_product.url }}">
                   <img src="{{ bundle_product.featured_media | image_url: width: 300 }}" alt="{{ bundle_product.title | escape }}" width="150" height="150" loading="lazy">
                 </a>
               </div>
               <div class="bundle-item__info">
                 <label class="bundle-item__checkbox-wrapper">
                   <input 
                      type="checkbox" 
                      class="bundle-item__checkbox" 
                      checked 
                      data-price="{{ bundle_product.price }}" 
                      data-variant-id="{{ bundle_product.selected_or_first_available_variant.id }}"
                   >
                   <span class="bundle-item__title">{{ bundle_product.title }}</span>
                 </label>
                 
                 {%- unless bundle_product.has_only_default_variant -%}
                   <div class="bundle-item__variants select">
                     <select class="select__select bundle-item__variant-select" name="id" form="ProductBundleForm-{{ section.id }}">
                       {%- for variant in bundle_product.variants -%}
                         <option value="{{ variant.id }}" data-price="{{ variant.price }}" {% if variant == bundle_product.selected_or_first_available_variant %}selected{% endif %}>
                           {{ variant.title }}
                         </option>
                       {%- endfor -%}
                     </select>
                   </div>
                 {%- else -%}
                    <input type="hidden" class="bundle-item__variant-select" value="{{ bundle_product.selected_or_first_available_variant.id }}">
                 {%- endunless -%}
                 
                 <span class="bundle-item__price price" data-base-price="{{ bundle_product.price }}">{{ bundle_product.price | money }}</span>
               </div>
            </div>
            
            {%- unless forloop.last -%}
              <div class="bundle-item__connector"><svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></div>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="bundle-item__connector bundle-item__connector--equals">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="5" y1="9" x2="19" y2="9"></line><line x1="5" y1="15" x2="19" y2="15"></line></svg>
        </div>
        
        {%- comment -%} Total & Submit Container {%- endcomment -%}
        <div class="bundle-summary">
          <div class="bundle-summary__totals">
            <span class="bundle-summary__label">{{ 'products.product.total_price' | t }}</span>
            <div class="bundle-summary__prices">
              {%- if section.settings.show_bundle_discount -%}
                <s class="bundle-summary__price-original" data-bundle-original-price></s>
              {%- endif -%}
              <span class="bundle-summary__price-final h3" data-bundle-total-price></span>
            </div>
          </div>
          
          <button type="button" class="button button--primary button--full-width bundle-summary__submit" id="AddBundle-{{ section.id }}">
            <span class="bundle-summary__submit-text">{{ section.settings.button_label }}</span>
            <div class="loading-overlay__spinner hidden">
              <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
              </svg>
            </div>
          </button>
          
          <div class="bundle-summary__error-message-wrapper" role="alert" hidden>
            <span class="bundle-summary__error-message"></span>
          </div>
        </div>

      </div>
    </product-bundle>
  </div>
</div>

{% stylesheet %}
  .product-bundle {
    --bundle-spacing: 2rem;
  }

  .product-bundle__heading {
    margin-bottom: 3rem;
  }

  .product-bundle__items {
    display: flex;
    align-items: center;
    gap: var(--bundle-spacing);
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: thin;
  }

  .bundle-item {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    flex: 0 0 200px; /* Fixed width for items */
  }

  .bundle-item__media img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--media-radius, 8px);
    background: #f4f4f4;
  }

  .bundle-item__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bundle-item__checkbox-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    cursor: pointer;
  }

  .bundle-item__checkbox {
    width: 2rem;
    height: 2rem;
    margin: 0;
    flex-shrink: 0;
    accent-color: rgba(var(--color-foreground), 1);
  }

  .bundle-item__title {
    font-size: 1.4rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bundle-item__variants {
    margin: 0.5rem 0;
  }

  .bundle-item__connector {
    color: rgba(var(--color-foreground), 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bundle-summary {
    flex: 0 0 280px;
    background: rgba(var(--color-foreground), 0.03);
    padding: 2.5rem;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    right: 0; /* Keeps it visible during scroll on desktop */
  }

  .bundle-summary__totals {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bundle-summary__prices {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .bundle-summary__price-original {
    color: rgba(var(--color-foreground), 0.6);
  }

  .bundle-summary__price-final {
    margin: 0;
    color: #e32c2b; /* Common highlight color */
  }

  @media screen and (max-width: 749px) {
    .product-bundle.product-bundle[style*="--bundle-layout: stack"] .product-bundle__items {
      flex-direction: column;
      align-items: stretch;
      overflow-x: visible;
    }

    .product-bundle.product-bundle[style*="--bundle-layout: stack"] .bundle-item {
      flex-direction: row;
      flex: auto;
    }

    .product-bundle.product-bundle[style*="--bundle-layout: stack"] .bundle-item__media {
      flex: 0 0 100px;
    }

    .product-bundle.product-bundle[style*="--bundle-layout: stack"] .bundle-item__connector {
      transform: rotate(90deg);
      padding: 1rem 0;
    }
    
    .bundle-summary {
      flex: auto;
      margin-top: 2rem;
      position: relative;
    }
  }
{% endstylesheet %}

<script>
  if (!customElements.get('product-bundle')) {
    customElements.define('product-bundle', class extends HTMLElement {
      constructor() {
        super();
        this.checkboxes = this.querySelectorAll('.bundle-item__checkbox');
        this.variantSelects = this.querySelectorAll('.bundle-item__variant-select');
        this.totalPriceElem = this.querySelector('[data-bundle-total-price]');
        this.originalPriceElem = this.querySelector('[data-bundle-original-price]');
        this.submitButton = this.querySelector('.bundle-summary__submit');
        this.errorWrapper = this.querySelector('.bundle-summary__error-message-wrapper');
        this.errorMessage = this.querySelector('.bundle-summary__error-message');
        
        this.discountPercentage = {{ section.settings.discount_percentage | default: 0 }} / 100;

        this.bindEvents();
        this.calculateTotal(); // Initial calc
      }

      bindEvents() {
        this.addEventListener('change', (e) => {
          if (e.target.matches('.bundle-item__checkbox')) {
             this.calculateTotal();
          }
          if (e.target.matches('.bundle-item__variant-select')) {
             const variantId = e.target.value;
             const price = e.target.options[e.target.selectedIndex].dataset.price;
             const container = e.target.closest('.bundle-item');
             
             // Update the hidden input/checkbox price and id data so calc matches the variant picked
             const checkbox = container.querySelector('.bundle-item__checkbox');
             checkbox.dataset.price = price;
             checkbox.dataset.variantId = variantId;
             
             // Optionally update the UI price display next to the selector
             const priceDisplay = container.querySelector('.bundle-item__price');
             if(priceDisplay) priceDisplay.innerHTML = this.formatMoney(price);

             this.calculateTotal();
          }
        });

        this.submitButton.addEventListener('click', this.addBundleToCart.bind(this));
      }

      calculateTotal() {
        let originalTotal = 0;
        let selectedCount = 0;

        this.checkboxes.forEach(box => {
          if (box.checked) {
            originalTotal += parseInt(box.dataset.price);
            selectedCount++;
          }
        });

        // Only apply discount if more than 1 item is selected
        let finalTotal = originalTotal;
        if (selectedCount > 1 && this.discountPercentage > 0) {
           finalTotal = originalTotal * (1 - this.discountPercentage);
           if (this.originalPriceElem) {
             this.originalPriceElem.innerHTML = this.formatMoney(originalTotal);
             this.originalPriceElem.hidden = false;
           }
        } else if (this.originalPriceElem) {
           this.originalPriceElem.hidden = true;
        }

        this.totalPriceElem.innerHTML = this.formatMoney(Math.round(finalTotal));
        
        if (selectedCount === 0) {
          this.submitButton.setAttribute('disabled', 'disabled');
        } else {
          this.submitButton.removeAttribute('disabled');
        }
      }

      addBundleToCart() {
        this.submitButton.setAttribute('aria-disabled', true);
        this.submitButton.classList.add('loading');
        this.querySelector('.loading-overlay__spinner').classList.remove('hidden');
        this.errorWrapper.hidden = true;

        const items = [];
        this.checkboxes.forEach(box => {
          if (box.checked) {
            items.push({
              id: box.dataset.variantId,
              quantity: 1
            });
          }
        });

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ items })
        })
        .then(response => response.json())
        .then(response => {
           if (response.status && response.status !== 200) {
              throw new Error(response.description);
           }
           // Emit event for Cart Drawer to catch and open
           document.dispatchEvent(new CustomEvent('cart:updated'));
        })
        .catch((error) => {
           this.errorWrapper.hidden = false;
           this.errorMessage.textContent = error.message || 'Error adding to cart';
        })
        .finally(() => {
           this.submitButton.removeAttribute('aria-disabled');
           this.submitButton.classList.remove('loading');
           this.querySelector('.loading-overlay__spinner').classList.add('hidden');
        });
      }

      formatMoney(cents) {
        // Quick fallback formatter, usually replaced by theme's global utility
        return Shopify.formatMoney ? Shopify.formatMoney(cents, window.theme.moneyFormat) : '$' + (cents / 100).toFixed(2);
      }
    });
  }
</script>

{% schema %}
{
  "name": "Product Bundle",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Bought Together"
    },
    {
      "type": "select",
      "id": "layout_mobile",
      "label": "Mobile Layout",
      "options": [
        { "value": "scroll", "label": "Horizontal Scroll" },
        { "value": "stack", "label": "Vertical Stack" }
      ],
      "default": "scroll"
    },
    {
      "type": "range",
      "id": "discount_percentage",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "%",
      "label": "Bundle Discount",
      "info": "Applied to subtotal when 2 or more items are selected.",
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_bundle_discount",
      "label": "Show savings display",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Add Bundle to Cart"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Bundle Product",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Bundle",
      "blocks": [
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
