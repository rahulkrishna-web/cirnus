{% stylesheet %}
  .announcement-bar {
    display: block;
    width: 100%;
    background-color: var(--announcement-bg, #000);
    color: var(--announcement-text, #fff);
    min-height: 40px;
    position: relative;
    z-index: 100;
  }
  
  .announcement-bar__ticker {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 2rem;
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    min-height: inherit;
  }

  .announcement-bar__item {
    animation: ticker var(--ticker-duration, 30s) linear infinite;
    padding: 0 2rem;
  }
  
  .announcement-bar__link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @keyframes ticker {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-100%, 0, 0); }
  }
{% endstylesheet %}

{%- if section.settings.show_announcement and section.settings.text != blank -%}
  <style>
    #shopify-section-{{ section.id }} .announcement-bar {
      --announcement-bg: {{ section.settings.background_color }};
      --announcement-text: {{ section.settings.text_color | default: '#ffffff' }};
      --ticker-duration: {{ section.settings.speed }}s;
    }
  </style>

  <div
    id="announcement-{{ section.id }}"
    class="announcement-bar color-scheme-{{ section.settings.color_scheme }}"
    aria-label="Store announcement"
  >
    <div class="announcement-bar__ticker">
      {%- for i in (1..6) -%}
        <span class="announcement-bar__item"{% if forloop.index > 1 %} aria-hidden="true"{% endif %}>
          {%- if section.settings.link != blank -%}
            <a href="{{ section.settings.link }}" class="announcement-bar__link" {% if forloop.index > 1 %}tabindex="-1"{% endif %}>
              {{ section.settings.text }}
            </a>
          {%- else -%}
            {{ section.settings.text }}
          {%- endif -%}
        </span>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        { "value": "1", "label": "Scheme 1" },
        { "value": "2", "label": "Scheme 2 (Inverse)" },
        { "value": "3", "label": "Scheme 3 (Accent)" }
      ],
      "default": "2"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Custom Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Custom Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Welcome to our store"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
