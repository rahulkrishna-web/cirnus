<div class="multicolumn section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient" style="--columns-desktop: {{ section.settings.columns_desktop }}; --align-content: {{ section.settings.column_alignment }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="multicolumn__header">
        <h2 class="multicolumn__heading h2">{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="multicolumn__wrapper">
      <ul class="multicolumn__list list-unstyled" role="list">
        {%- for block in section.blocks -%}
          <li class="multicolumn__list-item" {{ block.shopify_attributes }}>
            <div class="multicolumn__card">
              
              {%- if block.settings.image != blank -%}
                <div class="multicolumn__media multicolumn__media--{{ section.settings.image_width }}">
                  <img
                    src="{{ block.settings.image | image_url: width: 400 }}"
                    alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                    class="multicolumn__image"
                  >
                </div>
              {%- elsif block.settings.icon != 'none' -%}
                 <div class="multicolumn__icon multicolumn__icon--{{ section.settings.image_width }}">
                    <!-- Standardized SVG mappings. Can be abstracted to snippet later -->
                    {%- case block.settings.icon -%}
                      {%- when 'shipping' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                      {%- when 'returns' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 2v6h-6"></path><path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path><path d="M3 22v-6h6"></path><path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path></svg>
                      {%- when 'lock' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      {%- when 'star' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endcase -%}
                 </div>
              {%- endif -%}

              <div class="multicolumn__info">
                {%- if block.settings.title != blank -%}
                  <h3 class="multicolumn__title h4">{{ block.settings.title | escape }}</h3>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <div class="multicolumn__text rte">
                    {{ block.settings.text }}
                  </div>
                {%- endif -%}

                {%- if block.settings.link_label != blank -%}
                  <a class="link multicolumn__link" href="{{ block.settings.link }}" {% if block.settings.link == blank %}aria-disabled="true"{% endif %}>
                    {{ block.settings.link_label | escape }}
                  </a>
                {%- endif -%}
              </div>
              
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.button_label != blank -%}
        <div class="multicolumn__footer">
          <a href="{{ section.settings.button_link }}" class="button button--primary" {% if section.settings.button_link == blank %} aria-disabled="true"{% endif %}>
            {{ section.settings.button_label | escape }}
          </a>
        </div>
      {%- endif -%}
      
    </div>
  </div>
</div>

{% stylesheet %}
  .multicolumn {
    display: block;
    margin: 4rem 0;
  }

  .multicolumn__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .multicolumn__heading {
    margin: 0;
  }

  .multicolumn__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin: 0;
    padding: 0;
  }
  
  /* Desktop overrides */
  @media screen and (min-width: 750px) {
    .multicolumn__list {
      grid-template-columns: repeat(var(--columns-desktop, 3), 1fr);
      gap: 4rem;
    }
  }

  .multicolumn__list-item {
    display: flex;
    flex-direction: column;
  }

  .multicolumn__card {
    display: flex;
    flex-direction: column;
    align-items: var(--align-content, center);
    text-align: var(--align-content, center);
    height: 100%;
  }
  
  .multicolumn__card > * + * {
    margin-top: 2rem;
  }

  /* Media Constraints */
  .multicolumn__media, .multicolumn__icon {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    flex-shrink: 0; /* Prevent collapsing in weird flex conditions */
  }

  .multicolumn__media--small, .multicolumn__icon--small { width: 6rem; height: 6rem; }
  .multicolumn__media--medium, .multicolumn__icon--medium { width: 10rem; height: 10rem; }
  .multicolumn__media--large, .multicolumn__icon--large { width: 100%; aspect-ratio: 16/9; }

  .multicolumn__image,
  .multicolumn__icon svg {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .multicolumn__icon svg {
    width: 60%; /* Icons should have breathing room relative to container */
    height: 60%;
  }

  .multicolumn__info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }
  
  .multicolumn__title {
    margin: 0;
  }

  .multicolumn__text {
    margin: 0;
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.5rem;
  }
  
  .multicolumn__text p {
    margin: 0;
  }

  .multicolumn__link {
    margin-top: 0.5rem;
    display: inline-block;
    font-weight: 500;
  }

  .multicolumn__footer {
    display: flex;
    justify-content: center;
    margin-top: 5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Multicolumn",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Multicolumn",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center",
      "label": "Column alignment"
    },
    {
      "type": "select",
      "id": "image_width",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Full width" }
      ],
      "default": "small",
      "label": "Icon/Image size"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Global button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Global button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Fallback Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "shipping", "label": "Shipping Box" },
            { "value": "returns", "label": "Refresh/Returns" },
            { "value": "lock", "label": "Secure Lock" },
            { "value": "star", "label": "Quality Star" }
          ],
          "default": "shipping"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides fallback icon if selected."
        },
        {
          "type": "text",
          "id": "title",
          "default": "Column title",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an icon to focus on your store's features, trust signals, or product details.</p>",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multicolumn",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
