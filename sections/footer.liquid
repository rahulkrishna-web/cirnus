{% stylesheet %}
  .footer {
    background-color: var(--footer-bg-color, transparent);
    color: var(--footer-text-color, inherit);
    border-top: 1px solid var(--color-border);
    padding-top: var(--footer-padding-top, 3rem);
    padding-bottom: var(--footer-padding-bottom, 3rem);
    margin-top: auto;
  }
  .footer__blocks-wrapper {
    display: grid;
    grid-template-columns: repeat(var(--footer-grid-columns, 1), 1fr);
    gap: var(--space-8);
  }
  @media screen and (min-width: 750px) {
    .footer__blocks-wrapper {
      grid-template-columns: repeat(var(--footer-grid-columns-desktop, 4), 1fr);
    }
  }
  .footer__block-heading {
    margin-bottom: var(--space-4);
    font-size: var(--font-heading-scale);
  }
  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer__list-item a {
    text-decoration: none;
    color: inherit;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .footer__list-item a:hover {
    opacity: 1;
  }
{% endstylesheet %}

<footer class="footer" style="
  --footer-padding-top: {{ section.settings.padding_top }}px;
  --footer-padding-bottom: {{ section.settings.padding_bottom }}px;
  --footer-bg-color: {{ section.settings.color_scheme.settings.background }};
  --footer-text-color: {{ section.settings.color_scheme.settings.text }};
">
  <div class="page-width">
    {%- if section.blocks.size > 0 -%}
      <div class="footer__content-top">
        <div class="footer__blocks-wrapper" style="--footer-grid-columns-desktop: {{ section.blocks.size }};">
          {%- for block in section.blocks -%}
            <div class="footer-block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="footer__block-heading">{{ block.settings.heading | escape }}</h2>
              {%- endif -%}

              {%- case block.type -%}
                {%- when 'text' -%}
                  <div class="footer__block-content rte">
                    {{ block.settings.subtext }}
                  </div>
                {%- when 'link_list' -%}
                  {%- if block.settings.menu != blank -%}
                    <ul class="footer__list">
                      {%- for link in block.settings.menu.links -%}
                        <li class="footer__list-item">
                          <a href="{{ link.url }}">{{ link.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="footer__content-bottom">
      <div class="footer__copyright">
        <small class="copyright__content">&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}</small>
        {%- if section.settings.show_payment_icons -%}
          <div class="footer__payment">
            <span class="visually-hidden">Payment methods</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "default": true,
      "label": "Show payment icons"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Share contact information, store details, and brand content with your customers.</p>",
          "label": "Subtext"
        }
      ]
    }
  ]
}
{% endschema %}
