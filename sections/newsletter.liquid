<div class="newsletter section-{{ section.id }}-padding {% if section.settings.full_width %}newsletter--full-width{% endif %} color-{{ section.settings.color_scheme }} gradient">
  <div class="newsletter__wrapper page-width">
    <div class="newsletter__container">
      
      <div class="newsletter__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="newsletter__heading h2">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        
        {%- if section.settings.subheading != blank -%}
          <div class="newsletter__subheading rte">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
      </div>

      <div class="newsletter__form-wrapper">
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ 'newsletter.label' | t: default: 'Email address' }}"
                required
              >
              <label class="field__label visually-hidden" for="NewsletterForm--{{ section.id }}">
                {{ 'newsletter.label' | t: default: 'Email address' }}
              </label>
              
              <button type="submit" class="newsletter-form__button button button--primary" name="commit" id="Subscribe" aria-label="{{ 'newsletter.button_label' | t: default: 'Subscribe' }}">
                 <!-- Inline Arrow SVG to reduce requests -->
                 <svg viewBox="0 0 14 10" fill="none" class="icon icon-arrow" aria-hidden="true" focusable="false" role="presentation" xmlns="http://www.w3.org/2000/svg">
                   <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path>
                 </svg>
              </button>
            </div>
            
            {%- if form.errors -%}
              <small class="newsletter-form__message newsletter-form__message--error" id="Newsletter-error--{{ section.id }}">
                 <!-- Exclamation SVG -->
                 <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-error" viewBox="0 0 13 13">
                   <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                   <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                   <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                   <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7"/>
                 </svg>
                {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
              </small>
            {%- endif -%}
            
            {%- if form.posted_successfully? -%}
              <h3 class="newsletter-form__message newsletter-form__message--success" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
                <!-- Check SVG -->
                <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-success" viewBox="0 0 13 13">
                  <path d="M6.5 12.35C9.73087 12.35 12.35 9.73086 12.35 6.5C12.35 3.26913 9.73087 0.650002 6.5 0.650002C3.26913 0.650002 0.650002 3.26913 0.650002 6.5C0.650002 9.73086 3.26913 12.35 6.5 12.35Z" fill="#428445" stroke="white" stroke-width="0.7"/>
                  <path d="M5.53271 8.66357L9.25203 4.68197" stroke="white"/>
                  <path d="M4.10645 6.7688L6.13766 8.62553" stroke="white"/>
                </svg>
                {{ 'newsletter.success' | t: default: 'Thanks for subscribing' }}
              </h3>
            {%- endif -%}
          </div>
        {% endform %}
      </div>
      
    </div>
  </div>
</div>

{% stylesheet %}
  .newsletter {
    display: block;
    margin: 4rem 0;
  }
  
  .newsletter--full-width {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  
  .newsletter__wrapper {
    display: flex;
    justify-content: center;
  }

  .newsletter__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 60rem; /* Clamp width for readability */
    width: 100%;
    gap: 3rem;
  }

  /* Content */
  .newsletter__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .newsletter__heading {
    margin: 0;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
  }

  .newsletter__subheading {
    color: rgba(var(--color-foreground), 0.75);
    margin: 0;
  }

  /* Form */
  .newsletter__form-wrapper {
    width: 100%;
    max-width: 44rem; /* Nice constraint for the input field */
    margin: 0 auto;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .newsletter-form__field-wrapper {
    position: relative;
    width: 100%;
  }

  .field {
    display: flex;
    position: relative;
    width: 100%;
  }

  /* Input overrides for the newsletter specific look */
  .field__input {
    width: 100%;
    padding: 1.5rem 6rem 1.5rem 2rem; /* Make room for the button */
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: min(var(--buttons-radius), 2.5rem); /* Pill shape if supported */
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .field__input:focus {
    outline: none;
    border-color: rgb(var(--color-foreground));
    box-shadow: 0 0 0 1px rgb(var(--color-foreground));
  }

  /* Integrated adjacent button */
  .newsletter-form__button {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: auto;
  }

  .newsletter-form__button .icon-arrow {
    width: 1.6rem;
    height: auto;
  }

  /* Messages */
  .newsletter-form__message {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    gap: 0.8rem;
    font-size: 1.3rem;
  }

  .newsletter-form__message:focus-visible {
    outline: none;
    box-shadow: 0 0 0 0.2rem rgba(var(--color-foreground), 0.5);
  }

  .newsletter-form__message--success {
    color: #428445; /* Success Green */
  }

  .newsletter-form__message--error {
    color: #EB001B; /* Error Red */
  }

  .icon-error, .icon-success {
    width: 1.6rem;
    height: 1.6rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Subscribe to our emails",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "default": "<p>Be the first to know about new collections and exclusive offers.</p>",
      "label": "Subheading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "Make section full width"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
